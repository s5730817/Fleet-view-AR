PORT=5000

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Set DATA_SOURCE=postgres to force PostgreSQL-backed services.
# If left empty, the backend will use PostgreSQL automatically when DATABASE_URL
# or the PG* variables below are configured; otherwise it will stay in mock mode.
DATA_SOURCE=postgres

# Either provide DATABASE_URL or the PG* variables below.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGDATABASE=fleetar
PGUSER=
PGPASSWORD=
PGSSLMODE=
PGPOOLSIZE=10
